# .cursorignore — FinPay
# Files and directories that Cursor AI must never read, index, suggest edits to,
# or include in any context window. These contain secrets, PII, financial logic,
# or infrastructure config that must only be changed by a human with explicit intent.

# ── Secrets & Environment ─────────────────────────────────────────────────────
.env
.env.local
.env.staging
.env.production
.env.test
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
secrets/
vault/

# ── Authentication & Authorization ───────────────────────────────────────────
src/auth/
src/middleware/auth.ts
src/middleware/requirePermission.ts
src/middleware/requireMerchantScope.ts

# ── Financial Core ────────────────────────────────────────────────────────────
src/ledger/
src/audit/

# ── Database Migrations ───────────────────────────────────────────────────────
src/migrations/
db/migrations/
knex/migrations/

# ── Database & App Config ─────────────────────────────────────────────────────
src/config/secrets.ts
src/config/database.ts
src/config/production.ts
src/config/staging.ts

# ── Infrastructure & Deployment ───────────────────────────────────────────────
infrastructure/
terraform/
.github/workflows/
docker/
Dockerfile
docker-compose.yml
docker-compose.production.yml
k8s/
helm/
ansible/

# ── CI/CD & Pipeline ─────────────────────────────────────────────────────────
.github/
.gitlab-ci.yml
.circleci/
Jenkinsfile
scripts/deploy.sh
scripts/migrate-production.sh
scripts/seed-production.sh

# ── Logs & Crash Dumps ────────────────────────────────────────────────────────
logs/
*.log
*.dump
*.heapsnapshot

# ── Build Artifacts ───────────────────────────────────────────────────────────
dist/
build/
.next/
out/
coverage/

# ── Package Lock Files (read-only reference, never edit) ─────────────────────
package-lock.json
yarn.lock
pnpm-lock.yaml
